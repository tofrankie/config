{
  "name": "@tofrankie/prettier",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.0",
  "description": "Shared Prettier configuration",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/config/tree/main/packages/prettier",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/config.git",
    "directory": "packages/prettier"
  },
  "bugs": "https://github.com/tofrankie/config/issues",
  "keywords": [
    "prettier",
    "prettier-config",
    "prettier-plugin-organize-attributes",
    "format",
    "html",
    "miniprogram",
    "vue",
    "wechat",
    "wxml",
    "tofrankie"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./base": {
      "import": {
        "types": "./dist/base.d.mts",
        "default": "./dist/base.mjs"
      },
      "require": {
        "types": "./dist/base.d.cts",
        "default": "./dist/base.cjs"
      }
    },
    "./html": {
      "import": {
        "types": "./dist/html.d.mts",
        "default": "./dist/html.mjs"
      },
      "require": {
        "types": "./dist/html.d.cts",
        "default": "./dist/html.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.mts",
        "default": "./dist/vue.mjs"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./wxml": {
      "import": {
        "types": "./dist/wxml.d.mts",
        "default": "./dist/wxml.mjs"
      },
      "require": {
        "types": "./dist/wxml.d.cts",
        "default": "./dist/wxml.cjs"
      }
    },
    "./wxml-base": {
      "import": {
        "types": "./dist/wxml-base.d.mts",
        "default": "./dist/wxml-base.mjs"
      },
      "require": {
        "types": "./dist/wxml-base.d.cts",
        "default": "./dist/wxml-base.cjs"
      }
    },
    "./wechat-svg": {
      "import": {
        "types": "./dist/wechat-svg.d.mts",
        "default": "./dist/wechat-svg.mjs"
      },
      "require": {
        "types": "./dist/wechat-svg.d.cts",
        "default": "./dist/wechat-svg.cjs"
      }
    },
    "./organize-attributes": {
      "import": {
        "types": "./dist/organize-attributes.d.mts",
        "default": "./dist/organize-attributes.mjs"
      },
      "require": {
        "types": "./dist/organize-attributes.d.cts",
        "default": "./dist/organize-attributes.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "pnpm typecheck && pnpm build",
    "publint": "publint",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0"
  },
  "dependencies": {
    "@tofrankie/prettier-plugin-wxml": "catalog:prod",
    "prettier-plugin-organize-attributes": "catalog:prod"
  },
  "devDependencies": {
    "@tofrankie/tsconfig": "workspace:*",
    "prettier": "catalog:peer"
  }
}
