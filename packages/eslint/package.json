{
  "name": "@tofrankie/eslint",
  "type": "module",
  "version": "0.2.1",
  "packageManager": "pnpm@10.32.0",
  "description": "Shared ESLint configuration",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/config/tree/main/packages/eslint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/config.git",
    "directory": "packages/eslint"
  },
  "bugs": "https://github.com/tofrankie/config/issues",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "eslintconfig",
    "lint",
    "react",
    "typescript",
    "vue",
    "tofrankie"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "pnpm typecheck && pnpm build",
    "publint": "publint"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "dependencies": {
    "@angular-eslint/eslint-plugin": "catalog:prod",
    "@angular-eslint/eslint-plugin-template": "catalog:prod",
    "@angular-eslint/template-parser": "catalog:prod",
    "@antfu/eslint-config": "catalog:prod",
    "@eslint-react/eslint-plugin": "catalog:prod",
    "@next/eslint-plugin-next": "catalog:prod",
    "@prettier/plugin-xml": "catalog:prod",
    "@unocss/eslint-plugin": "catalog:prod",
    "defu": "catalog:prod",
    "eslint-plugin-astro": "catalog:prod",
    "eslint-plugin-format": "catalog:prod",
    "eslint-plugin-jsdoc": "catalog:prod",
    "eslint-plugin-jsx-a11y": "catalog:prod",
    "eslint-plugin-react-refresh": "catalog:prod",
    "eslint-plugin-solid": "catalog:prod",
    "eslint-plugin-svelte": "catalog:prod",
    "find-up-simple": "catalog:prod",
    "local-pkg": "catalog:prod",
    "prettier-plugin-astro": "catalog:prod"
  },
  "devDependencies": {
    "@tofrankie/tsconfig": "workspace:*",
    "eslint": "catalog:peer"
  }
}
