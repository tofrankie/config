{
  "name": "@tofrankie/eslint",
  "type": "module",
  "version": "0.0.19",
  "packageManager": "pnpm@10.32.0",
  "description": "Shared ESLint configuration",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/config/tree/main/packages/eslint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/config.git",
    "directory": "packages/eslint"
  },
  "bugs": "https://github.com/tofrankie/config/issues",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "eslintconfig",
    "lint",
    "react",
    "typescript",
    "vue",
    "tofrankie"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "publint": "publint"
  },
  "peerDependencies": {
    "eslint": "^9.10.0 || ^10.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "catalog:prod",
    "@eslint-react/eslint-plugin": "catalog:prod",
    "eslint-plugin-format": "catalog:prod",
    "eslint-plugin-jsdoc": "catalog:prod",
    "eslint-plugin-react-refresh": "catalog:prod",
    "lodash.merge": "catalog:prod"
  },
  "devDependencies": {
    "@tofrankie/tsconfig": "workspace:*",
    "@types/lodash.merge": "catalog:types",
    "eslint": "catalog:peer"
  }
}
