{
  "name": "@tofrankie/tsconfig",
  "type": "module",
  "version": "0.1.3",
  "packageManager": "pnpm@10.32.0",
  "description": "Shared TypeScript configuration",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/config/tree/main/packages/tsconfig",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/config.git",
    "directory": "packages/tsconfig"
  },
  "bugs": "https://github.com/tofrankie/config/issues",
  "keywords": [
    "tsconfig",
    "typescript",
    "typescript-config",
    "node",
    "react",
    "tsdown",
    "vite",
    "vitest",
    "vue",
    "tofrankie"
  ],
  "bin": {
    "tsconfig": "./dist/index.mjs"
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "node.app.json",
    "node.lib.json",
    "react.app.json",
    "react.lib.json",
    "strict.json",
    "vitest.node.json",
    "vitest.web.json",
    "vue.app.json",
    "vue.lib.json",
    "web.app.json"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "dev:cli": "tsdown --watch",
    "build": "run-s build:tsconfig build:cli json:lint",
    "build:tsconfig": "node ./scripts/build-tsconfig.ts",
    "build:cli": "tsdown",
    "typecheck": "tsc --noEmit",
    "json:lint": "run-s json:sort json:sort json:sort json:format",
    "json:sort": "eslint --fix --config ./eslint.config.js >/dev/null 2>&1 || true",
    "json:format": "prettier ./**/*.json --write --log-level silent",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "publint": "publint"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "catalog:prod",
    "ansis": "catalog:prod",
    "commander": "catalog:prod",
    "execa": "catalog:prod",
    "tsconfck": "catalog:prod"
  },
  "devDependencies": {
    "@tsconfig/node20": "catalog:prod",
    "@tsconfig/strictest": "catalog:prod",
    "@tsconfig/vite-react": "catalog:prod",
    "@vue/tsconfig": "catalog:prod",
    "eslint-plugin-jsonc": "catalog:dev",
    "jsonc-parser": "catalog:dev",
    "publint": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
