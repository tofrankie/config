{
  "name": "@tofrankie/stylelint",
  "type": "module",
  "version": "0.0.12",
  "packageManager": "pnpm@10.32.0",
  "description": "Shared Stylelint configuration",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/config/tree/main/packages/stylelint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/config.git",
    "directory": "packages/stylelint"
  },
  "bugs": "https://github.com/tofrankie/config/issues",
  "keywords": [
    "stylelint",
    "stylelint-config",
    "stylelint-order",
    "lint",
    "tofrankie"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./standard": {
      "import": {
        "types": "./dist/standard.d.mts",
        "default": "./dist/standard.mjs"
      },
      "require": {
        "types": "./dist/standard.d.cts",
        "default": "./dist/standard.cjs"
      }
    },
    "./miniprogram": {
      "import": {
        "types": "./dist/miniprogram.d.mts",
        "default": "./dist/miniprogram.mjs"
      },
      "require": {
        "types": "./dist/miniprogram.d.cts",
        "default": "./dist/miniprogram.cjs"
      }
    },
    "./uniapp": {
      "import": {
        "types": "./dist/uniapp.d.mts",
        "default": "./dist/uniapp.mjs"
      },
      "require": {
        "types": "./dist/uniapp.d.cts",
        "default": "./dist/uniapp.cjs"
      }
    },
    "./min-pixel": {
      "import": {
        "types": "./dist/min-pixel.d.mts",
        "default": "./dist/min-pixel.mjs"
      },
      "require": {
        "types": "./dist/min-pixel.d.cts",
        "default": "./dist/min-pixel.cjs"
      }
    },
    "./scss": {
      "import": {
        "types": "./dist/scss.d.mts",
        "default": "./dist/scss.mjs"
      },
      "require": {
        "types": "./dist/scss.d.cts",
        "default": "./dist/scss.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.mts",
        "default": "./dist/vue.mjs"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./vue-scss": {
      "import": {
        "types": "./dist/vue-scss.d.mts",
        "default": "./dist/vue-scss.mjs"
      },
      "require": {
        "types": "./dist/vue-scss.d.cts",
        "default": "./dist/vue-scss.cjs"
      }
    },
    "./wechat-svg": {
      "import": {
        "types": "./dist/wechat-svg.d.mts",
        "default": "./dist/wechat-svg.mjs"
      },
      "require": {
        "types": "./dist/wechat-svg.d.cts",
        "default": "./dist/wechat-svg.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "publint": "publint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "stylelint": "^17.6.0"
  },
  "dependencies": {
    "@stylistic/stylelint-plugin": "catalog:prod",
    "deepmerge": "catalog:prod",
    "postcss": "catalog:prod",
    "postcss-html": "catalog:prod",
    "postcss-scss": "catalog:prod",
    "stylelint-config-html": "catalog:prod",
    "stylelint-config-recess-order": "catalog:prod",
    "stylelint-config-standard": "catalog:prod",
    "stylelint-config-standard-scss": "catalog:prod",
    "stylelint-config-standard-vue": "catalog:prod",
    "stylelint-order": "catalog:prod"
  },
  "devDependencies": {
    "stylelint": "catalog:peer"
  }
}
