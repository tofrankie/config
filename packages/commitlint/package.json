{
  "name": "@tofrankie/commitlint",
  "type": "module",
  "version": "0.0.5",
  "packageManager": "pnpm@10.32.0",
  "description": "A shared commitlint configuration",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/config/tree/main/packages/commitlint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/config.git",
    "directory": "packages/commitlint"
  },
  "bugs": "https://github.com/tofrankie/config/issues",
  "keywords": [
    "commitlint",
    "commitlint-config",
    "conventional-commits",
    "lint",
    "tofrankie"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "publint": "publint"
  },
  "peerDependencies": {
    "@commitlint/cli": ">=20.0.0"
  },
  "dependencies": {
    "@commitlint/config-conventional": "catalog:prod"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:peer",
    "@commitlint/types": "catalog:types",
    "@tofrankie/tsconfig": "workspace:*"
  }
}
